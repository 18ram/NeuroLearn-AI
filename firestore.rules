rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['title', 'content']) &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 100000;
    }

    function isValidQuiz(data) {
      return data.keys().hasAll(['questions', 'difficulty']) &&
             data.questions is list &&
             data.difficulty in ['easy', 'medium', 'hard'];
    }

    function isValidFlashcard(data) {
      return data.keys().hasAll(['front', 'back']) &&
             data.front is string && data.front.size() < 1000 &&
             data.back is string && data.back.size() < 1000;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['score', 'totalQuestions']) &&
             data.score is number &&
             data.totalQuestions is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      // Documents
      match /documents/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDocument(request.resource.data);
        allow update: if isOwner(userId) && isValidDocument(request.resource.data);
        allow delete: if isOwner(userId);
        
        // Quizzes
        match /quizzes/{quizId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidQuiz(request.resource.data);
          allow update: if isOwner(userId) && isValidQuiz(request.resource.data);
          allow delete: if isOwner(userId);
        }
        
        // Flashcards
        match /flashcards/{cardId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidFlashcard(request.resource.data);
          allow update: if isOwner(userId) && isValidFlashcard(request.resource.data);
          allow delete: if isOwner(userId);
        }
      }
      
      // Progress
      match /progress/{progressId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidProgress(request.resource.data);
        allow update: if isOwner(userId) && isValidProgress(request.resource.data);
      }
    }
  }
}
